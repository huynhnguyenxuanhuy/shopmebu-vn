<%# ===== TRANG TÀI KHOẢN ===== %>
<div class="account-page">
  <div class="container">

    <nav class="breadcrumb">
      <a href="/"><i class="fas fa-home"></i> Trang Chủ</a>
      <i class="fas fa-chevron-right"></i>
      <span>Tài Khoản</span>
    </nav>

    <%# FLASH %>
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success_msg[0] %></div>
    <% } %>

    <%# USER INFO %>
    <div class="user-header">
      <div class="user-avatar-wrap">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="Avatar" class="user-avatar">
        <% } else { %>
          <div class="user-avatar-default"><%= user.username.charAt(0).toUpperCase() %></div>
        <% } %>
      </div>
      <div class="user-meta">
        <h1 class="user-name"><%= user.username %></h1>
        <span class="user-role role-<%= user.role %>"><%= user.role === 'staff' ? 'CTV' : user.role %></span>
        <p class="user-email"><i class="fas fa-envelope"></i> <%= user.email %></p>
      </div>
      <div class="user-balance-big">
        <span class="ub-label">Số dư</span>
        <span class="ub-value"><%= Number(user.balance).toLocaleString('vi-VN') %>đ</span>
        <a href="/nap-tien" class="btn-naptien"><i class="fas fa-plus"></i> Nạp Tiền</a>
      </div>
    </div>


<% if (user.role === 'staff') { %>
<div class="user-balance-big" style="margin-top:12px;background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1px solid #86efac">
  <span class="ub-label">Số dư CTV</span>
  <span class="ub-value" style="color:#16a34a"><%= Number(user.ctv_balance||0).toLocaleString('vi-VN') %>đ</span>
  <button onclick="document.getElementById('ctvWithdrawModal').style.display='flex'" class="btn-naptien" style="background:#16a34a"><i class="fas fa-money-bill-wave"></i> Rút Tiền</button>
</div>
<div class="admin-card" style="margin-top:12px;">
  <div class="admin-card-body">
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
      <div style="flex:1;min-width:220px;">
        <div style="font-size:12px;color:#888;margin-bottom:6px;">Link giới thiệu CTV</div>
        <input id="ctvRefLink" readonly value="<%= (typeof siteUrl !== 'undefined' ? siteUrl : '') || '' %>/?ctv=<%= user.id %>" style="width:100%;padding:9px;border:1px solid rgba(255,255,255,0.14);border-radius:8px;background:rgba(255,255,255,0.04);color:#fff;">
      </div>
      <button type="button" onclick="copyCtvLink()" class="btn-naptien" style="border:none;cursor:pointer;"><i class="fas fa-copy"></i> Copy Link</button>
    </div>
  </div>
</div>
<!-- CTV Withdraw Modal -->
<div id="ctvWithdrawModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;justify-content:center;align-items:center">
  <div style="background:#fff;padding:28px;border-radius:14px;width:380px;max-width:95vw">
    <h3 style="margin-bottom:16px">Yêu Cầu Rút Tiền CTV</h3>
    <p style="margin-bottom:12px;color:#555">Số dư hiện tại: <strong style="color:#16a34a"><%= Number(user.ctv_balance||0).toLocaleString('vi-VN') %>đ</strong></p>
    <input id="wAmt" type="number" placeholder="Số tiền muốn rút" style="width:100%;margin-bottom:10px;padding:9px;border:1px solid #ddd;border-radius:7px;box-sizing:border-box">
    <input id="wBank" placeholder="Tên ngân hàng (VD: TPBank)" style="width:100%;margin-bottom:10px;padding:9px;border:1px solid #ddd;border-radius:7px;box-sizing:border-box">
    <input id="wNum" placeholder="Số tài khoản" style="width:100%;margin-bottom:10px;padding:9px;border:1px solid #ddd;border-radius:7px;box-sizing:border-box">
    <input id="wHolder" placeholder="Tên chủ tài khoản" style="width:100%;margin-bottom:14px;padding:9px;border:1px solid #ddd;border-radius:7px;box-sizing:border-box">
    <div style="display:flex;gap:10px">
      <button onclick="submitWithdraw()" style="flex:1;background:#16a34a;color:#fff;border:none;padding:10px;border-radius:7px;cursor:pointer;font-weight:600">Gửi Yêu Cầu</button>
      <button onclick="document.getElementById('ctvWithdrawModal').style.display='none'" style="flex:1;border:1px solid #ddd;padding:10px;border-radius:7px;cursor:pointer">Huỷ</button>
    </div>
    <p id="wMsg" style="margin-top:10px;text-align:center"></p>
  </div>
</div>
<script>
async function submitWithdraw() {
  const amount = document.getElementById('wAmt').value;
  const bank_name = document.getElementById('wBank').value;
  const bank_number = document.getElementById('wNum').value;
  const bank_holder = document.getElementById('wHolder').value;
  if (!amount || !bank_name || !bank_number || !bank_holder) { document.getElementById('wMsg').textContent='Vui lòng điền đầy đủ thông tin'; return; }
  const r = await fetch('/api/ctv/withdraw', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({amount,bank_name,bank_number,bank_holder})});
  const d = await r.json();
  document.getElementById('wMsg').style.color = d.success ? 'green' : 'red';
  document.getElementById('wMsg').textContent = d.message;
  if (d.success) setTimeout(() => location.reload(), 1500);
}
async function copyCtvLink() {
  const el = document.getElementById('ctvRefLink');
  const link = el.value || (location.origin + '/?ctv=<%= user.id %>');
  try {
    await navigator.clipboard.writeText(link);
    alert('Đã copy link giới thiệu CTV.');
  } catch (_) {
    el.select();
    document.execCommand('copy');
    alert('Đã copy link giới thiệu CTV.');
  }
}
</script>
<% } %>

    <%# TABS %>
    <div class="account-tabs">
      <button class="tab-btn active" onclick="showTab('orders', this)"><i class="fas fa-shopping-bag"></i> Lịch Sử Mua</button>
      <button class="tab-btn" onclick="showTab('transactions', this)"><i class="fas fa-exchange-alt"></i> Giao Dịch</button>
      <% if (user.role === 'staff') { %>
        <button class="tab-btn" onclick="showTab('ctv', this)"><i class="fas fa-handshake"></i> CTV</button>
      <% } %>
    </div>

    <%# TAB: ORDERS %>
    <div class="tab-content active" id="tab-orders">
      <% if (orders && orders.length > 0) { %>
      <div class="orders-list">
        <% orders.forEach(o => { %>
        <div class="order-card">
          <div class="order-game"><%= o.game_icon %> <%= o.game_name %></div>
          <div class="order-main">
            <div class="order-rank"><i class="fas fa-trophy"></i> <%= o.rank || 'N/A' %></div>
            <div class="order-specs">
              <% if (o.so_tuong > 0) { %><span><i class="fas fa-user-ninja"></i> <%= o.so_tuong %> tướng</span><% } %>
              <% if (o.trang_phuc > 0) { %><span><i class="fas fa-tshirt"></i> <%= o.trang_phuc %> phục</span><% } %>
            </div>
          </div>
          <div class="order-right">
            <div class="order-price"><%= Number(o.amount).toLocaleString('vi-VN') %>đ</div>
            <div class="order-date"><i class="far fa-clock"></i> <%= new Date(o.created_at).toLocaleString('vi-VN') %></div>
            <button class="btn-view-acc" onclick="toggleAcc(this, '<%= o.acc_username %>', '<%= o.acc_password %>', `<%= o.acc_info || '' %>`)">
              <i class="fas fa-eye"></i> Xem Thông Tin Acc
            </button>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-shopping-bag"></i>
        <p>Bạn chưa mua acc nào</p>
        <a href="/" class="btn-filter">Mua Acc Ngay</a>
      </div>
      <% } %>
    </div>

    <%# TAB: TRANSACTIONS %>
    <div class="tab-content" id="tab-transactions">
      <% if (transactions && transactions.length > 0) { %>
      <div class="tx-table-wrap">
        <table class="tx-table">
          <thead>
            <tr>
              <th>Thời Gian</th>
              <th>Loại</th>
              <th>Số Tiền</th>
              <th>Số Dư Sau</th>
              <th>Ghi Chú</th>
              <th>Trạng Thái</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach(tx => { %>
            <tr>
              <td><%= new Date(tx.created_at).toLocaleString('vi-VN') %></td>
              <td>
                <span class="type-badge type-<%= tx.type %>">
                  <% if (tx.type === 'deposit') { %>⬆️ Nạp tiền
                  <% } else if (tx.type === 'purchase') { %>⬇️ Mua acc
                  <% } else { %>🔄 Hoàn tiền<% } %>
                </span>
              </td>
              <td class="<%= tx.type === 'deposit' || tx.type === 'refund' ? 'tx-plus' : 'tx-minus' %>">
                <%= tx.type === 'deposit' || tx.type === 'refund' ? '+' : '-' %><%= Number(tx.amount).toLocaleString('vi-VN') %>đ
              </td>
              <td><%= Number(tx.balance_after).toLocaleString('vi-VN') %>đ</td>
              <td class="tx-note"><%= tx.note || tx.transfer_content || '—' %></td>
              <td>
                <span class="status-badge <%= tx.status %>">
                  <%= tx.status === 'success' ? '✅ Thành công' : tx.status === 'pending' ? '⏳ Đang xử lý' : '❌ Thất bại' %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-inbox"></i>
        <p>Chưa có giao dịch nào</p>
      </div>
      <% } %>
    </div>

    <% if (user.role === 'staff') { %>
    <div class="tab-content" id="tab-ctv">
      <div class="admin-card" style="margin-bottom:18px;">
        <div class="admin-card-header"><h3>Đăng acc CTV</h3></div>
        <div class="admin-card-body">
          <form action="/ctv/dang-acc" method="POST" enctype="multipart/form-data" class="admin-form">
            <div class="form-grid">
              <div class="form-group">
                <label>Game</label>
                <select name="game_slug" required>
                  <% (ctvGames || []).forEach(game => { %>
                    <option value="<%= game.slug %>"><%= game.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label>Giá bán</label>
                <input type="number" name="price" min="0" step="1000" placeholder="VD: 100000" required>
              </div>
              <div class="form-group">
                <label>Tài khoản acc</label>
                <input type="text" name="acc_username" placeholder="Username acc" required>
              </div>
              <div class="form-group">
                <label>Mật khẩu acc</label>
                <input type="text" name="acc_password" placeholder="Password acc" required>
              </div>
              <div class="form-group">
                <label>Tiêu đề</label>
                <input type="text" name="title" placeholder="VD: Acc VIP giá tốt">
              </div>
              <div class="form-group">
                <label>Rank / Gói</label>
                <input type="text" name="rank_name" placeholder="VD: VIP, 100K">
              </div>
              <div class="form-group">
                <label>Server</label>
                <input type="text" name="server" placeholder="Server">
              </div>
              <div class="form-group">
                <label>Ảnh acc</label>
                <input type="file" name="image" id="ctvImageInput" accept="image/*">
                <div id="ctvPasteHint" style="font-size:12px;color:var(--text-muted);margin-top:6px;">Có thể copy ảnh rồi bấm Ctrl+V vào trang này.</div>
                <img id="ctvImagePreview" alt="Ảnh acc đã chọn" style="display:none;margin-top:10px;width:120px;height:82px;object-fit:cover;border-radius:8px;border:1px solid var(--border);">
              </div>
              <div class="form-group">
                <label>Lưu ý sau khi mua</label>
                <input type="text" name="acc_info" placeholder="Lưu ý giao cho khách">
              </div>
            </div>
            <button type="submit" class="btn-naptien" style="border:none;cursor:pointer;">
              <i class="fas fa-plus-circle"></i> Đăng Acc
            </button>
          </form>
        </div>
      </div>

      <div class="admin-card" style="margin-bottom:18px;">
        <div class="admin-card-header"><h3>Lịch sử bán acc CTV</h3></div>
        <div class="admin-card-body">
          <% if (ctvSales && ctvSales.length > 0) { %>
          <div class="tx-table-wrap">
            <table class="tx-table">
              <thead>
                <tr>
                  <th>Thời Gian</th>
                  <th>Acc</th>
                  <th>Game</th>
                  <th>Số Tiền</th>
                  <th>%</th>
                  <th>Trạng Thái</th>
                </tr>
              </thead>
              <tbody>
                <% ctvSales.forEach(s => { %>
                <tr>
                  <td><%= new Date(s.created_at).toLocaleString('vi-VN') %></td>
                  <td>#<%= s.account_id %> - <%= s.title || s.acc_username || 'Acc đã bán' %></td>
                  <td><%= s.game_name || 'N/A' %></td>
                  <td class="tx-plus">+<%= Number(s.amount).toLocaleString('vi-VN') %>đ</td>
                  <td><%= Number(s.commission_percent || 100).toLocaleString('vi-VN') %>%</td>
                  <td><span class="status-badge success">Đã cộng tiền</span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
          <div class="empty-state">
            <i class="fas fa-handshake"></i>
            <p>Chưa có acc CTV nào bán được</p>
          </div>
          <% } %>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header"><h3>Lịch sử rút tiền CTV</h3></div>
        <div class="admin-card-body">
          <% if (ctvWithdrawals && ctvWithdrawals.length > 0) { %>
          <div class="tx-table-wrap">
            <table class="tx-table">
              <thead>
                <tr>
                  <th>Thời Gian</th>
                  <th>Số Tiền</th>
                  <th>Ngân Hàng</th>
                  <th>Trạng Thái</th>
                </tr>
              </thead>
              <tbody>
                <% ctvWithdrawals.forEach(w => { %>
                <tr>
                  <td><%= new Date(w.created_at).toLocaleString('vi-VN') %></td>
                  <td><%= Number(w.amount).toLocaleString('vi-VN') %>đ</td>
                  <td class="tx-note"><%= w.bank_info || '—' %></td>
                  <td>
                    <span class="status-badge <%= w.status === 'approved' ? 'success' : w.status %>">
                      <%= w.status === 'approved' ? 'Đã duyệt' : w.status === 'pending' ? 'Chờ duyệt' : 'Từ chối' %>
                    </span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } else { %>
          <div class="empty-state">
            <i class="fas fa-money-bill-wave"></i>
            <p>Chưa có yêu cầu rút tiền</p>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

  </div>
</div>

<%# ACC INFO MODAL %>
<div class="modal-overlay" id="accModal" style="display:none">
  <div class="modal-box">
    <div class="modal-header">
      <h3><i class="fas fa-key"></i> Thông Tin Acc</h3>
      <button onclick="document.getElementById('accModal').style.display='none'" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" id="accModalBody"></div>
  </div>
</div>

<style>
.account-page { padding: 20px 0 60px; }
.user-header {
  display: flex; align-items: center; gap: 24px;
  background: var(--card-bg);
  border-radius: 14px; padding: 24px;
  margin-bottom: 24px;
  border: 1px solid rgba(255,255,255,0.07);
  flex-wrap: wrap;
}
.user-avatar { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid var(--primary); }
.user-avatar-default {
  width: 80px; height: 80px; border-radius: 50%;
  background: var(--primary); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; font-weight: 700;
}
.user-meta { flex: 1; }
.user-name { font-size: 1.5rem; color: #fff; margin-bottom: 6px; }
.user-role {
  padding: 2px 12px; border-radius: 12px; font-size: 0.75rem; font-weight: 700;
  text-transform: uppercase;
}
.role-customer { background: rgba(108,99,255,0.2); color: var(--primary); }
.role-admin    { background: rgba(231,76,60,0.2); color: #e74c3c; }
.role-staff    { background: rgba(243,156,18,0.2); color: var(--accent); }
.user-email { color: #888; font-size: 0.85rem; margin-top: 6px; }
.user-balance-big { text-align: center; }
.ub-label { display: block; color: #888; font-size: 0.8rem; margin-bottom: 4px; }
.ub-value { display: block; font-size: 1.8rem; font-weight: 900; color: var(--accent); margin-bottom: 10px; }
.btn-naptien {
  display: inline-block; background: var(--primary);
  color: #fff; text-decoration: none;
  padding: 7px 20px; border-radius: 8px; font-size: 0.9rem;
}

.account-tabs {
  display: flex; gap: 4px; margin-bottom: 20px;
  background: var(--card-bg); padding: 4px; border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.07);
  width: fit-content;
}
.account-tabs .tab-btn {
  background: none; border: none; color: #888;
  padding: 8px 20px; border-radius: 8px; cursor: pointer;
  font-size: 0.9rem; transition: all 0.2s;
}
.account-tabs .tab-btn.active { background: var(--primary); color: #fff; }

.tab-content { display: none; }
.tab-content.active { display: block; }

.orders-list { display: flex; flex-direction: column; gap: 12px; }
.order-card {
  background: var(--card-bg); border-radius: 10px;
  padding: 16px 20px;
  display: flex; align-items: center; gap: 16px;
  border: 1px solid rgba(255,255,255,0.06);
  flex-wrap: wrap;
}
.order-game { color: #888; font-size: 0.8rem; width: 120px; flex-shrink: 0; }
.order-main { flex: 1; }
.order-rank { color: #fff; font-weight: 700; margin-bottom: 4px; }
.order-specs { display: flex; gap: 10px; }
.order-specs span { color: #aaa; font-size: 0.8rem; }
.order-right { text-align: right; }
.order-price { color: var(--accent); font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
.order-date { color: #666; font-size: 0.78rem; margin-bottom: 8px; }
.btn-view-acc {
  background: rgba(108,99,255,0.15); color: var(--primary);
  border: 1px solid var(--primary); padding: 5px 12px;
  border-radius: 6px; font-size: 0.8rem; cursor: pointer; transition: all 0.2s;
}
.btn-view-acc:hover { background: var(--primary); color: #fff; }

.tx-table-wrap { overflow-x: auto; }
.tx-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.tx-table th {
  background: rgba(108,99,255,0.2); color: #ccc;
  padding: 10px 12px; text-align: left; white-space: nowrap;
}
.tx-table td { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.04); color: #ddd; }
.tx-table tr:hover td { background: rgba(255,255,255,0.02); }
.tx-plus { color: #2ecc71; font-weight: 700; }
.tx-minus { color: #e74c3c; font-weight: 700; }
.tx-note { color: #777; font-size: 0.78rem; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.type-badge, .status-badge { font-size: 0.78rem; white-space: nowrap; }

.empty-state { text-align: center; padding: 50px; color: #555; }
.empty-state i { font-size: 3rem; margin-bottom: 14px; display: block; }
.btn-filter {
  display: inline-block; background: var(--primary); color: #fff;
  text-decoration: none; padding: 8px 20px; border-radius: 8px;
  font-size: 0.9rem; margin-top: 12px;
}

.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.75);
  display: flex; align-items: center; justify-content: center; z-index: 1000;
}
.modal-box {
  background: var(--card-bg); border-radius: 12px;
  border: 1px solid var(--primary); width: 90%; max-width: 420px; overflow: hidden;
}
.modal-header { background: var(--primary); padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; }
.modal-header h3 { margin: 0; color: #fff; font-size: 1rem; }
.modal-close { background: none; border: none; color: #fff; cursor: pointer; font-size: 1.2rem; }
.modal-body { padding: 24px; }
.cred-row {
  display: flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,0.05); padding: 10px 14px;
  border-radius: 8px; margin-bottom: 10px;
}
.cred-row label { color: #aaa; font-size: 0.8rem; width: 100px; flex-shrink: 0; }
.cred-row span { color: var(--accent); font-family: monospace; font-weight: 700; flex: 1; font-size: 0.95rem; word-break: break-all; }
.btn-copy-sm {
  background: rgba(108,99,255,0.2); color: var(--primary);
  border: none; padding: 3px 8px; border-radius: 4px; cursor: pointer; font-size: 0.75rem;
}
</style>

<script>
function showTab(name, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.account-tabs .tab-btn').forEach(b => b.classList.remove('active'));
  const tab = document.getElementById('tab-' + name);
  if (!tab) return;
  tab.classList.add('active');
  const activeBtn = btn || document.querySelector(`.account-tabs .tab-btn[onclick*="'${name}'"]`);
  if (activeBtn) activeBtn.classList.add('active');
}
document.addEventListener('DOMContentLoaded', () => {
  if (window.location.hash === '#ctv') showTab('ctv');
});
const ctvImageInput = document.getElementById('ctvImageInput');
const ctvImagePreview = document.getElementById('ctvImagePreview');
if (ctvImageInput && ctvImagePreview) {
  ctvImageInput.addEventListener('change', () => {
    const file = ctvImageInput.files && ctvImageInput.files[0];
    if (!file) return;
    ctvImagePreview.src = URL.createObjectURL(file);
    ctvImagePreview.style.display = 'block';
  });
  document.addEventListener('paste', event => {
    const items = event.clipboardData && event.clipboardData.items;
    if (!items) return;
    const item = Array.from(items).find(i => i.type && i.type.startsWith('image/'));
    if (!item) return;
    const file = item.getAsFile();
    if (!file) return;
    const namedFile = new File([file], 'ctv-paste-' + Date.now() + '.png', { type: file.type || 'image/png' });
    const transfer = new DataTransfer();
    transfer.items.add(namedFile);
    ctvImageInput.files = transfer.files;
    ctvImagePreview.src = URL.createObjectURL(namedFile);
    ctvImagePreview.style.display = 'block';
  });
}
function toggleAcc(btn, user, pass, info) {
  document.getElementById('accModal').style.display = 'flex';
  document.getElementById('accModalBody').innerHTML = `
    <div class="cred-row">
      <label>Tên đăng nhập:</label>
      <span>${user}</span>
      <button onclick="navigator.clipboard.writeText('${user}')" class="btn-copy-sm"><i class="fas fa-copy"></i></button>
    </div>
    <div class="cred-row">
      <label>Mật khẩu:</label>
      <span>${pass}</span>
      <button onclick="navigator.clipboard.writeText('${pass}')" class="btn-copy-sm"><i class="fas fa-copy"></i></button>
    </div>
    ${info ? `<div class="cred-row"><label>Thông tin:</label><span style="color:#ccc;font-size:0.82rem">${info}</span></div>` : ''}
    <p style="color:#888;font-size:0.78rem;margin-top:10px"><i class="fas fa-shield-alt"></i> Đổi mật khẩu ngay sau khi nhận acc!</p>
  `;
}
document.getElementById('accModal')?.addEventListener('click', e => {
  if (e.target.id === 'accModal') e.target.style.display = 'none';
});
</script>

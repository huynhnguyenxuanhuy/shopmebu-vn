    <div style="font-size:10px;color:rgba(255,255,255,.35);margin-top:2px;">Admin Panel</div>
    <div style="font-size:11px;color:rgba(255,255,255,.5);margin-top:6px;">
      👤 <%= admin.username %> <span style="font-size:9px;background:rgba(230,21,21,.3);color:#ff6a6a;padding:1px 6px;border-radius:8px;margin-left:4px;"><%= admin.role %></span>
    </div>
  </div>
  <nav class="admin-nav">
    <div class="admin-nav-section">Tổng Quan</div>
    <a href="/admin" class="admin-nav-link <%= page_name==='dashboard'?'active':'' %>">
      <span class="nav-icon">📊</span> Dashboard
    </a>

    <div class="admin-nav-section">Kho Hàng</div>

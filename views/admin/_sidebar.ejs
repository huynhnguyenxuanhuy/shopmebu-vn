      min-height: 100vh !important;
    }
    #adminSidebar.admin-sidebar {
      position: fixed !important;
      left: 0 !important;
      top: 0 !important;
      bottom: 0 !important;
      width: 250px !important;
      height: 100vh !important;
      z-index: 180 !important;
      overflow-y: auto !important;
      transform: none !important;
    }
    .admin-main {
      margin-left: 250px !important;
      min-height: 100vh !important;
    }
  }
  @media (max-width: 768px) {
    html,
    body {
      overflow-x: hidden !important;
    }
    .admin-layout {
      display: block !important;
      width: 100% !important;
      min-height: 100vh !important;
    }
    #adminSidebar.admin-sidebar {
      position: fixed !important;
      left: -260px !important;
      top: 0 !important;
      bottom: 0 !important;
      width: 250px !important;
      height: 100vh !important;
      height: 100dvh !important;
      z-index: 2000 !important;
      overflow-y: auto !important;
      transform: none !important;
      transition: left .25s ease !important;
      box-shadow: none !important;
    }
    #adminSidebar.admin-sidebar.open {
      left: 0 !important;
      box-shadow: 4px 0 30px rgba(0,0,0,.4) !important;
    }
    #adminSidebarOverlay.admin-sidebar-overlay {
      display: none !important;
      position: fixed !important;
      inset: 0 !important;
      background: rgba(0,0,0,.5) !important;
      z-index: 1999 !important;
      backdrop-filter: blur(2px) !important;
    }
    #adminSidebarOverlay.admin-sidebar-overlay.open {
      display: block !important;
    }
    .admin-main {
      width: 100% !important;
      margin-left: 0 !important;
      overflow-x: hidden !important;
    }
    .admin-topbar {
      padding: 12px 14px !important;
      gap: 10px !important;
      position: sticky !important;
      top: 0 !important;
    }
    .admin-topbar h1 {
      min-width: 0 !important;
      font-size: 15px !important;
      line-height: 1.25 !important;
      overflow: hidden !important;
      text-overflow: ellipsis !important;
      white-space: nowrap !important;
    }
    .admin-menu-btn {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      flex: 0 0 40px !important;
      width: 40px !important;
      height: 40px !important;
      margin-right: 0 !important;
      border: 0 !important;
      border-radius: 10px !important;
      background: var(--primary-light) !important;
      color: var(--primary) !important;
      font-size: 20px !important;
    }
    .admin-content {
      padding: 14px 10px !important;
    }
    .admin-stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 10px !important;
      margin-bottom: 16px !important;
    }
    .admin-stat-card,
    .admin-card {
      border-radius: 12px !important;
    }
    .admin-stat-card {
      padding: 14px 12px !important;
    }
    .admin-stat-value {
      font-size: 20px !important;
      word-break: break-word !important;
    }
    .admin-card-header {
      padding: 12px 14px !important;
      gap: 10px !important;
      flex-wrap: wrap !important;
    }
    .admin-card-header h3 {
      font-size: 14px !important;
      line-height: 1.3 !important;
    }
    .admin-card-body {
      padding: 14px !important;
    }
    .admin-form .form-row,
    .admin-form .form-grid,
    .admin-content div[style*="display:grid"] {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }
    .admin-card-body form[style*="display:flex"],
    .admin-card-body div[style*="display:flex"] {
      flex-wrap: wrap !important;
    }
    .search-input,
    .form-control,
    .admin-form input,
    .admin-form select,
    .admin-form textarea {
      max-width: 100% !important;
      min-width: 0 !important;
    }
    .table-wrapper {
      width: 100% !important;
      overflow-x: auto !important;
      -webkit-overflow-scrolling: touch !important;
    }
    .data-table {
      min-width: 720px !important;
    }
    .data-table th,
    .data-table td {
      padding: 9px 10px !important;
      font-size: 11.5px !important;
      white-space: nowrap !important;
    }
    canvas {
      max-height: 240px !important;
    }
  }
</style>
<!-- Mobile overlay -->
<div class="admin-sidebar-overlay" id="adminSidebarOverlay" onclick="toggleAdminSidebar()"></div>

<script>
function toggleAdminSidebar() {
  const sidebar = document.getElementById('adminSidebar');
  const overlay = document.getElementById('adminSidebarOverlay');
  if (!sidebar) return;
  const isOpen = sidebar.classList.contains('open');
  sidebar.classList.toggle('open', !isOpen);
  overlay.classList.toggle('open', !isOpen);
  document.body.style.overflow = isOpen ? '' : 'hidden';
}

(function initAdminAlerts() {
  if (window.__shopmebuAdminAlerts) return;
  window.__shopmebuAdminAlerts = true;

  let lastState = null;
  let firstLoad = true;

  function ensureToastRoot() {
    let root = document.getElementById('adminAlertToasts');
    if (!root) {
      root = document.createElement('div');
      root.id = 'adminAlertToasts';
      root.style.cssText = 'position:fixed;right:18px;top:18px;z-index:99999;display:flex;flex-direction:column;gap:10px;max-width:360px;';
      document.body.appendChild(root);
    }
    return root;
  }

  function showAdminToast(title, message, href) {
    const root = ensureToastRoot();
    const toast = document.createElement('a');
    toast.href = href || '/admin';
    toast.style.cssText = [
      'display:block;text-decoration:none;color:#fff;border-radius:16px;padding:14px 16px',
      'background:linear-gradient(135deg,#111,#7b0008 52%,#e60012)',
      'box-shadow:0 16px 36px rgba(230,0,18,.35);border:1px solid rgba(255,255,255,.18)',
      'font-family:Be Vietnam Pro,Arial,sans-serif;transform:translateX(110%);opacity:0;transition:all .28s ease'
    ].join(';');
    toast.innerHTML = `
      <div style="display:flex;align-items:center;gap:10px;font-weight:900;font-size:14px;">
        <span style="width:30px;height:30px;border-radius:50%;background:#fff;color:#e60012;display:inline-flex;align-items:center;justify-content:center;">🔔</span>
        <span>${title}</span>
      </div>
      <div style="font-size:12.5px;line-height:1.5;margin-top:8px;color:rgba(255,255,255,.88);">${message}</div>
      <div style="font-size:11px;font-weight:900;margin-top:10px;color:#ffd7d7;">Bấm để xem ngay →</div>
    `;
    root.appendChild(toast);
    requestAnimationFrame(() => {
      toast.style.transform = 'translateX(0)';
      toast.style.opacity = '1';
    });
    setTimeout(() => {
      toast.style.transform = 'translateX(110%)';
      toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 320);
    }, 7000);
  }

  async function checkAdminAlerts() {
    try {
      const res = await fetch('/admin/alerts/status', { headers: { 'Accept': 'application/json' } });
      if (!res.ok) return;
      const data = await res.json();
      if (!data.success) return;

      if (firstLoad) {
        if (data.pendingPayments > 0) {
          showAdminToast('Có payment chờ xử lý', `${data.pendingPayments} giao dịch đang chờ admin duyệt.`, '/admin/payments?filter=unprocessed');
        }
        if (data.pendingWithdrawals > 0) {
          showAdminToast('Có yêu cầu rút tiền CTV', `${data.pendingWithdrawals} yêu cầu rút tiền đang chờ duyệt.`, '/admin/ctv');
        }
        firstLoad = false;
      } else if (lastState) {
        if (data.pendingPayments > lastState.pendingPayments) {
          showAdminToast('Payment mới cần xử lý', `Có ${data.pendingPayments - lastState.pendingPayments} giao dịch mới chờ duyệt.`, '/admin/payments?filter=unprocessed');
        }
        if (data.pendingWithdrawals > lastState.pendingWithdrawals) {
          showAdminToast('CTV vừa gửi yêu cầu rút', `Có ${data.pendingWithdrawals - lastState.pendingWithdrawals} yêu cầu rút tiền mới.`, '/admin/ctv');
        }
      }

      lastState = data;
    } catch (_) {}
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', checkAdminAlerts);
  } else {
    checkAdminAlerts();
  }
  setInterval(checkAdminAlerts, 10000);
})();
</script>


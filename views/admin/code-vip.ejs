<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="/favicon.ico?v=15" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=15">
  <link rel="apple-touch-icon" href="/favicon.png?v=15">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no">
  <title>Đăng Code VIP - Admin SHOPMEBU</title>
  <link rel="stylesheet" href="/css/style.css?v=15">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('_sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar">
      <button class="admin-menu-btn" onclick="toggleAdminSidebar()" aria-label="Menu"><i class="fas fa-bars"></i></button>
      <h1>🎟️ Đăng Code VIP</h1>
    </div>
    <div class="admin-content">
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash flash-success">✅ <%= success_msg[0] %></div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flash flash-error">❌ <%= error_msg[0] %></div>
      <% } %>

      <div class="admin-card" style="margin-bottom:20px;">
        <div class="admin-card-header"><h3>Thêm Code VIP</h3></div>
        <div class="admin-card-body">
          <form action="/admin/code-vip/them" method="POST" enctype="multipart/form-data" class="admin-form">
            <div class="form-grid">
              <div class="form-group">
                <label>Code</label>
                <input type="text" name="code" placeholder="Nhập code giao cho khách" required>
              </div>
              <div class="form-group">
                <label>Giá</label>
                <input type="number" name="price" min="0" step="1000" placeholder="VD: 100000" required>
              </div>
              <div class="form-group">
                <label>Tiêu đề</label>
                <input type="text" name="title" placeholder="VD: Code tri ân, code web" required>
              </div>
              <div class="form-group">
                <label>Chi tiết</label>
                <textarea name="acc_info" rows="3" placeholder="VD: combo 5 code tổng 25 lệnh hảo kiệt, 10 lệnh chiêm tinh, 3000 knb"></textarea>
              </div>
              <div class="form-group">
                <label>Ảnh Code VIP</label>
                <input type="file" name="images" id="codeVipImages" accept="image/*" multiple>
                <div id="codeVipPreview" style="display:none;margin-top:10px;gap:8px;flex-wrap:wrap;"></div>
              </div>
            </div>
            <button type="submit" class="btn btn-primary">✅ Đăng Code VIP</button>
          </form>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header"><h3>Code VIP Đã Đăng</h3></div>
        <div class="admin-card-body" style="padding:0;">
          <div class="table-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Tiêu đề</th>
                  <th>Code</th>
                  <th>Chi tiết</th>
                  <th>Giá</th>
                  <th>Trạng thái</th>
                  <th>Ngày tạo</th>
                </tr>
              </thead>
              <tbody>
                <% if (codeList && codeList.length > 0) { %>
                  <% codeList.forEach(item => { %>
                    <tr>
                      <td><strong>#<%= item.id %></strong></td>
                      <td><%= item.title || 'Code VIP' %></td>
                      <td style="font-family:monospace;font-weight:800;"><%= item.acc_username %></td>
                      <td style="font-size:12px;color:var(--text-muted);max-width:260px;white-space:normal;"><%= item.acc_info || '—' %></td>
                      <td style="font-weight:900;color:var(--primary);"><%= Number(item.price || 0).toLocaleString('vi-VN') %>đ</td>
                      <td><span class="status-badge <%= item.status === 'available' ? 'status-success' : 'status-pending' %>"><%= item.status === 'available' ? 'Còn bán' : item.status %></span></td>
                      <td style="font-size:12px;color:var(--text-muted);"><%= item.created_at ? new Date(item.created_at).toLocaleString('vi-VN') : '—' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="7" style="text-align:center;padding:28px;color:var(--text-muted);">Chưa có Code VIP nào</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
const codeVipImages = document.getElementById('codeVipImages');
const codeVipPreview = document.getElementById('codeVipPreview');
if (codeVipImages && codeVipPreview) {
  let selectedCodeVipImages = [];
  const renderCodeVipPreview = () => {
    codeVipPreview.innerHTML = '';
    if (!selectedCodeVipImages.length) {
      codeVipPreview.style.display = 'none';
      return;
    }
    selectedCodeVipImages.forEach(file => {
      const img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.alt = file.name || 'Ảnh code';
      img.style.cssText = 'width:120px;height:82px;object-fit:cover;border-radius:8px;border:1px solid var(--border);';
      codeVipPreview.appendChild(img);
    });
    codeVipPreview.style.display = 'flex';
  };
  codeVipImages.addEventListener('change', () => {
    const files = Array.from(codeVipImages.files || []);
    selectedCodeVipImages = selectedCodeVipImages.concat(files).slice(0, 8);
    const transfer = new DataTransfer();
    selectedCodeVipImages.forEach(file => transfer.items.add(file));
    codeVipImages.files = transfer.files;
    renderCodeVipPreview();
  });
}
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="/favicon.ico?v=12" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=12">
  <link rel="apple-touch-icon" href="/favicon.png?v=12">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no">
  <title>Đăng Code VIP - Admin SHOPMEBU</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('_sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar">
      <button class="admin-menu-btn" onclick="toggleAdminSidebar()" aria-label="Menu"><i class="fas fa-bars"></i></button>
      <h1>🎟️ Đăng Code VIP</h1>
    </div>
    <div class="admin-content">
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash flash-success">✅ <%= success_msg[0] %></div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flash flash-error">❌ <%= error_msg[0] %></div>
      <% } %>

      <div class="admin-card" style="margin-bottom:20px;">
        <div class="admin-card-header"><h3>Thêm Code VIP</h3></div>
        <div class="admin-card-body">
          <form action="/admin/code-vip/them" method="POST" class="admin-form">
            <div class="form-grid">
              <div class="form-group">
                <label>Code</label>
                <input type="text" name="code" placeholder="Nhập code giao cho khách" required>
              </div>
              <div class="form-group">
                <label>Giá</label>
                <input type="number" name="price" min="0" step="1000" placeholder="VD: 100000" required>
              </div>
              <div class="form-group">
                <label>Tiêu đề</label>
                <input type="text" name="title" placeholder="Code VIP">
              </div>
              <div class="form-group">
                <label>Lưu ý sau khi mua</label>
                <input type="text" name="acc_info" placeholder="Lưu ý hiển thị khi khách mua xong">
              </div>
            </div>
            <button type="submit" class="btn btn-primary">✅ Đăng Code VIP</button>
          </form>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header"><h3>Code VIP Đã Đăng</h3></div>
        <div class="admin-card-body" style="padding:0;">
          <div class="table-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Tiêu đề</th>
                  <th>Code</th>
                  <th>Giá</th>
                  <th>Trạng thái</th>
                  <th>Ngày tạo</th>
                </tr>
              </thead>
              <tbody>
                <% if (codeList && codeList.length > 0) { %>
                  <% codeList.forEach(item => { %>
                    <tr>
                      <td><strong>#<%= item.id %></strong></td>
                      <td><%= item.title || 'Code VIP' %></td>
                      <td style="font-family:monospace;font-weight:800;"><%= item.acc_username %></td>
                      <td style="font-weight:900;color:var(--primary);"><%= Number(item.price || 0).toLocaleString('vi-VN') %>đ</td>
                      <td><span class="status-badge <%= item.status === 'available' ? 'status-success' : 'status-pending' %>"><%= item.status === 'available' ? 'Còn bán' : item.status %></span></td>
                      <td style="font-size:12px;color:var(--text-muted);"><%= item.created_at ? new Date(item.created_at).toLocaleString('vi-VN') : '—' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="6" style="text-align:center;padding:28px;color:var(--text-muted);">Chưa có Code VIP nào</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>

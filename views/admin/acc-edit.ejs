<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="/favicon.ico?v=12" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=12">
  <link rel="apple-touch-icon" href="/favicon.png?v=12">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no">
  <title>Sửa Acc – Admin SHOPMEBU</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('_sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><button class="admin-menu-btn" onclick="toggleAdminSidebar()" aria-label="Menu"><i class="fas fa-bars"></i></button>
      <h1>✏️ Sửa Acc #<%= acc.id %></h1>
      <a href="/admin/acc" class="btn btn-outline btn-sm">← Danh Sách Acc</a>
    </div>
    <div class="admin-content">
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash flash-success">✅ <%= success_msg[0] %></div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flash flash-error">❌ <%= error_msg[0] %></div>
      <% } %>

      <div class="admin-card">
        <div class="admin-card-header"><h3>🎮 Thông Tin Acc</h3></div>
        <div class="admin-card-body">
          <form method="POST" action="/admin/acc/sua/<%= acc.id %>" enctype="multipart/form-data" class="admin-form">
            <div class="form-row">
              <div class="form-group">
                <label>Game *</label>
                <select name="game_slug" required>
                  <% games.forEach(g => { %>
                    <option value="<%= g.slug %>" <%= acc.game_slug===g.slug?'selected':'' %>><%= g.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label>Loại Acc</label>
                <select name="acc_type">
                  <option value="tu-chon" <%= acc.acc_type==='tu-chon'?'selected':'' %>>Tự Chọn</option>
                  <option value="random" <%= acc.acc_type==='random'?'selected':'' %>>Random / Túi Mù</option>
                  <option value="vip" <%= acc.acc_type==='vip'?'selected':'' %>>VIP Cao Cấp</option>
                  <option value="reg" <%= acc.acc_type==='reg'?'selected':'' %>>REG Mới</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>Username Acc *</label>
                <input type="text" name="acc_username" value="<%= acc.acc_username || '' %>" required>
              </div>
              <div class="form-group">
                <label>Password Acc *</label>
                <input type="text" name="acc_password" value="<%= acc.acc_password || '' %>" required>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>Giá Bán (đ) *</label>
                <input type="number" name="price" value="<%= acc.price || 0 %>" min="1000" required>
              </div>
              <div class="form-group">
                <label>Rank / Hạng</label>
                <input type="text" name="rank_name" value="<%= acc.rank || '' %>">
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>Server</label>
                <input type="text" name="server" value="<%= acc.server || '' %>">
              </div>
              <div class="form-group">
                <label>CTV bán acc</label>
                <select name="ctv_id">
                  <option value="">Shop giữ acc</option>
                  <% (ctvUsers || []).forEach(ctv => { %>
                    <option value="<%= ctv.id %>" <%= Number(acc.ctv_id || 0) === Number(ctv.id) ? 'selected' : '' %>>#<%= ctv.id %> - <%= ctv.username %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>Ảnh mới (tùy chọn)</label>
                <input type="file" name="images" id="editImageInput" accept="image/*" multiple>
                <div id="editImagePreview" style="display:none;margin-top:10px;gap:8px;flex-wrap:wrap;"></div>
              </div>
            </div>

            <div class="form-group">
              <label>Tiêu Đề Hiển Thị</label>
              <input type="text" name="title" value="<%= acc.title || '' %>">
            </div>

            <div class="form-group">
              <label>Thông Tin Thêm (hiển thị sau khi mua)</label>
              <textarea name="acc_info"><%= acc.acc_info || '' %></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;padding:13px;font-size:15px;">
              💾 Lưu Thay Đổi
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
const editImageInput = document.getElementById('editImageInput');
const editImagePreview = document.getElementById('editImagePreview');
let selectedEditImages = [];
if (editImageInput && editImagePreview) {
  editImageInput.addEventListener('change', () => {
    const incomingFiles = Array.from(editImageInput.files || []);
    if (!incomingFiles.length) return;
    selectedEditImages = selectedEditImages.concat(incomingFiles).slice(0, 8);
    const transfer = new DataTransfer();
    selectedEditImages.forEach(file => transfer.items.add(file));
    editImageInput.files = transfer.files;
    editImagePreview.innerHTML = '';
    selectedEditImages.forEach(file => {
      const img = document.createElement('img');
      img.src = URL.createObjectURL(file);
      img.alt = file.name || 'Ảnh acc';
      img.style.cssText = 'width:120px;height:82px;object-fit:cover;border-radius:8px;border:1px solid var(--border);';
      editImagePreview.appendChild(img);
    });
    editImagePreview.style.display = 'flex';
  });
}
</script>
</body>
</html>

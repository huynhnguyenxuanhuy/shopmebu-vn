<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đơn Hàng – Admin SHOPMEBU</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('_sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><button class="admin-menu-btn" onclick="toggleAdminSidebar()" aria-label="Menu"><i class="fas fa-bars"></i></button>
      <h1>🛒 Đơn Hàng <span style="font-size:14px;font-weight:600;color:var(--text-muted);">(<%= total %> đơn)</span></h1>
    </div>
    <div class="admin-content">

      <div class="admin-card" style="margin-bottom:18px;">
        <div class="admin-card-body" style="padding:14px 20px;">
          <form method="GET" style="display:flex;gap:12px;align-items:flex-end;">
            <div class="filter-group">
              <label>Tìm kiếm</label>
              <input type="text" name="search" value="<%= search %>" placeholder="Username / acc username..." class="search-input" style="min-width:260px;">
            </div>
            <button class="btn btn-primary btn-sm" type="submit">🔍 Tìm</button>
            <a href="/admin/orders" class="btn btn-outline btn-sm">↺ Reset</a>
          </form>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-body" style="padding:0;">
          <div class="table-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>User</th>
                  <th>Acc Username</th>
                  <th>Game</th>
                  <th>Giá</th>
                  <th>Trạng Thái</th>
                  <th>Thời Gian</th>
                  <th>Xem Acc</th>
                </tr>
              </thead>
              <tbody>
                <% if (orders.length > 0) { %>
                  <% orders.forEach(o => { %>
                  <tr>
                    <td><strong>#<%= o.id %></strong></td>
                    <td style="font-weight:700;"><%= o.username %></td>
                    <td style="font-family:monospace;font-size:12px;"><%= o.acc_username %></td>
                    <td style="font-size:12px;"><%= o.game_slug %></td>
                    <td style="font-weight:800;color:var(--primary);"><%= Number(o.amount).toLocaleString('vi-VN') %>đ</td>
                    <td>
                      <span class="status-badge <%= o.status==='completed'?'status-success':'status-pending' %>">
                        <%= o.status==='completed' ? '✅ Hoàn tất' : o.status %>
                      </span>
                    </td>
                    <td style="font-size:11px;color:var(--text-muted);"><%= new Date(o.created_at).toLocaleString('vi-VN') %></td>
                    <td>
                      <button class="btn btn-outline btn-sm" onclick="viewOrder('<%= o.acc_username %>', '<%= (o.acc_password||'').replace(/'/g,'') %>', '<%= (o.acc_info||'').replace(/'/g,'').substring(0,150) %>')">👁️</button>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="8" style="text-align:center;padding:28px;color:var(--text-muted);">Không có đơn hàng nào</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if(page>1){%><a href="?page=<%=page-1%>&search=<%=search%>">‹</a><%}%>
        <%for(let i=1;i<=totalPages;i++){%><%if(i===page){%><span class="active"><%=i%></span><%}else if(i<=2||i>totalPages-2||Math.abs(i-page)<=2){%><a href="?page=<%=i%>&search=<%=search%>"><%=i%></a><%}else if(Math.abs(i-page)===3){%><span>…</span><%}%><%}%>
        <% if(page<totalPages){%><a href="?page=<%=page+1%>&search=<%=search%>">›</a><%}%>
      </div>
      <% } %>
    </div>
  </div>
</div>

<div class="modal-overlay" id="orderModal">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('orderModal').classList.remove('active')">✕</button>
    <h2>👁️ Thông Tin Acc Đã Giao</h2>
    <div class="acc-result-box" style="margin-top:16px;">
      <div class="acc-result-row"><span class="lbl">Username</span><span class="val" id="oUser">---</span></div>
      <div class="acc-result-row"><span class="lbl">Password</span><span class="val" id="oPass">---</span></div>
      <div class="acc-result-row"><span class="lbl">Info</span><span class="val" id="oInfo" style="font-size:11px;word-break:break-all;">---</span></div>
    </div>
  </div>
</div>

<script>
function viewOrder(u, p, i) {
  document.getElementById('oUser').textContent = u;
  document.getElementById('oPass').textContent = p;
  document.getElementById('oInfo').textContent = i || '(không có)';
  document.getElementById('orderModal').classList.add('active');
}
</script>
</body>
</html>

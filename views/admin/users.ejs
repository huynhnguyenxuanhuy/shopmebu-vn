<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản Lý Users – Admin SHOPMEBU</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('_sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><button class="admin-menu-btn" onclick="toggleAdminSidebar()" aria-label="Menu"><i class="fas fa-bars"></i></button>
      <h1>👥 Quản Lý Users <span style="font-size:14px;font-weight:600;color:var(--text-muted);">(<%= total %> người)</span></h1>
    </div>
    <div class="admin-content">

      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flash flash-success">✅ <%= success_msg[0] %></div>
      <% } %>

      <%# SEARCH %>
      <div class="admin-card" style="margin-bottom:18px;">
        <div class="admin-card-body" style="padding:14px 20px;">
          <form method="GET" style="display:flex;gap:12px;align-items:flex-end;">
            <div class="filter-group">
              <label>Tìm kiếm</label>
              <input type="text" name="search" value="<%= search %>" placeholder="Username / email..." class="search-input" style="min-width:280px;">
            </div>
            <button class="btn btn-primary btn-sm" type="submit">🔍 Tìm</button>
            <a href="/admin/users" class="btn btn-outline btn-sm">↺ Reset</a>
          </form>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-body" style="padding:0;">
          <div class="table-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>#ID</th>
                  <th>Username</th>
                  <th>Email</th>
                  <th>Số Dư</th>
                  <th>Đơn Hàng</th>
                  <th>Tổng Nạp</th>
                  <th>Role</th>
                  <th>Ngày ĐK</th>
                  <th>Hành Động</th>
                </tr>
              </thead>
              <tbody>
                <% if (users.length > 0) { %>
                  <% users.forEach(u => { %>
                  <tr>
                    <td><strong>#<%= u.id %></strong></td>
                    <td>
                      <div style="font-weight:700;"><%= u.username %></div>
                      <% if (!u.is_active) { %><span style="font-size:10px;color:var(--primary);">🔴 Khoá</span><% } %>
                    </td>
                    <td style="font-size:12px;color:var(--text-muted);"><%= u.email || '—' %></td>
                    <td style="font-weight:800;color:var(--primary);"><%= Number(u.balance||0).toLocaleString('vi-VN') %>đ</td>
                    <td style="font-weight:700;"><%= u.order_count %></td>
                    <td style="font-size:12px;"><%= Number(u.total_deposit||0).toLocaleString('vi-VN') %>đ</td>
                    <td>
                      <span class="badge-role badge-<%= u.role %>"><%= u.role %></span>
                    </td>
                    <td style="font-size:11px;color:var(--text-muted);"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn btn-outline btn-sm" onclick="openAdjust(<%= u.id %>, '<%= u.username %>', <%= u.balance||0 %>)">💰</button>
                        <button class="btn btn-outline btn-sm" style="border-color:var(--accent-yellow);color:#856404;" onclick="openRole(<%= u.id %>, '<%= u.username %>', '<%= u.role %>')">🔑</button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="9" style="text-align:center;padding:28px;color:var(--text-muted);">Không tìm thấy user nào</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <%# PAGINATION %>
      <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page>1) { %><a href="?page=<%= page-1 %>&search=<%= search %>">‹</a><% } %>
        <% for(let i=1;i<=totalPages;i++) { %>
          <% if(i===page){%><span class="active"><%=i%></span><%}else if(i<=2||i>totalPages-2||Math.abs(i-page)<=2){%><a href="?page=<%=i%>&search=<%=search%>"><%=i%></a><%}else if(Math.abs(i-page)===3){%><span>…</span><%}%>
        <% } %>
        <% if (page<totalPages) { %><a href="?page=<%= page+1 %>&search=<%= search %>">›</a><% } %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%# ADJUST BALANCE MODAL %>
<div class="modal-overlay" id="adjustModal">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('adjustModal').classList.remove('active')">✕</button>
    <h2>💰 Điều Chỉnh Số Dư</h2>
    <p id="adjustUserName" style="font-size:13px;color:var(--text-muted);margin:6px 0 16px;"></p>
    <div class="admin-form">
      <input type="hidden" id="adjUserId">
      <div class="form-group">
        <label>Số tiền (dương = cộng, âm = trừ)</label>
        <input type="number" id="adjAmount" placeholder="VD: 50000 hoặc -50000">
      </div>
      <div class="form-group">
        <label>Ghi chú</label>
        <input type="text" id="adjNote" placeholder="Lý do điều chỉnh...">
      </div>
      <div id="adjMsg" style="font-size:13px;margin-bottom:12px;display:none;"></div>
      <button class="btn btn-primary" onclick="submitAdjust()" style="width:100%;">💰 Xác Nhận</button>
    </div>
  </div>
</div>

<%# ROLE MODAL %>
<div class="modal-overlay" id="roleModal">
  <div class="modal-box">
    <button class="modal-close" onclick="document.getElementById('roleModal').classList.remove('active')">✕</button>
    <h2>🔑 Đổi Role</h2>
    <p id="roleUserName" style="font-size:13px;color:var(--text-muted);margin:6px 0 16px;"></p>
    <div class="admin-form">
      <input type="hidden" id="roleUserId">
      <div class="form-group">
        <label>Role mới</label>
        <select id="roleValue">
          <option value="customer">customer</option>
          <option value="staff">staff</option>
          <option value="admin">admin</option>
          <option value="superadmin">superadmin</option>
        </select>
      </div>
      <div id="roleMsg" style="font-size:13px;margin-bottom:12px;display:none;"></div>
      <button class="btn btn-primary" onclick="submitRole()" style="width:100%;">✅ Cập Nhật Role</button>
    </div>
  </div>
</div>

<script>
function openAdjust(id, name, balance) {
  document.getElementById('adjUserId').value = id;
  document.getElementById('adjustUserName').textContent = name + ' – Số dư hiện tại: ' + balance.toLocaleString('vi-VN') + 'đ';
  document.getElementById('adjAmount').value = '';
  document.getElementById('adjNote').value = '';
  document.getElementById('adjMsg').style.display = 'none';
  document.getElementById('adjustModal').classList.add('active');
}

async function submitAdjust() {
  const userId = document.getElementById('adjUserId').value;
  const amount = document.getElementById('adjAmount').value;
  const note   = document.getElementById('adjNote').value;
  const msg    = document.getElementById('adjMsg');
  if (!amount) { msg.style.display='block'; msg.style.color='var(--primary)'; msg.textContent='⚠️ Nhập số tiền!'; return; }
  const fd = new FormData();
  fd.append('user_id', userId); fd.append('amount', amount); fd.append('note', note);
  const r = await fetch('/admin/users/adjust-balance', { method:'POST', body:fd });
  const d = await r.json();
  msg.style.display='block';
  msg.style.color = d.success ? '#00c853' : 'var(--primary)';
  msg.textContent = d.message;
  if (d.success) setTimeout(() => location.reload(), 1500);
}

function openRole(id, name, role) {
  document.getElementById('roleUserId').value = id;
  document.getElementById('roleUserName').textContent = 'User: ' + name + ' – Role hiện tại: ' + role;
  document.getElementById('roleValue').value = role;
  document.getElementById('roleMsg').style.display = 'none';
  document.getElementById('roleModal').classList.add('active');
}

async function submitRole() {
  const user_id = document.getElementById('roleUserId').value;
  const role    = document.getElementById('roleValue').value;
  const msg     = document.getElementById('roleMsg');
  const fd = new FormData();
  fd.append('user_id', user_id); fd.append('role', role);
  const r = await fetch('/admin/users/set-role', { method:'POST', body:fd });
  const d = await r.json();
  msg.style.display='block';
  msg.style.color = d.success ? '#00c853' : 'var(--primary)';
  msg.textContent = d.message;
  if (d.success) setTimeout(() => location.reload(), 1200);
}
</script>
</body>
</html>

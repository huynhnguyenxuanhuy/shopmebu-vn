<%# ===== CHI TIẾT ACC ===== %>
<%
  const detailFallbackThumbs = [
    'https://play-lh.googleusercontent.com/556FIxsnMJWgLOOSTgAbL1ceIynb3xQv6vjL_7hBTOpaiZaX1yxk21YEefZo4q7K=w1052-h592',
    'https://play-lh.googleusercontent.com/e1r-JdALc5NcU_YwYHAyLzfSk3OsX6JC9yYb_D7KVOnJs04ML0lhUuob0GE1ze_4IJM=w1052-h592',
    'https://gianghokyngo.vplay.vn/home/img/bg-page3.jpg',
    'https://gianghokyngo.vplay.vn/home/img/img-slide.png',
    'https://play-lh.googleusercontent.com/EkeG-CnfqSe8Nq50orgfa1qFBpUDtI4ya8Z1lw1BjBeo6JdIqCpYDO7B5kaR3k41DI3R=w1052-h592',
    'https://gianghokyngo.vplay.vn/home/img/bg-page1.jpg',
    'https://gianghokyngo.vplay.vn/home/img/bg-page4.jpg',
    'https://play-lh.googleusercontent.com/i6WceP8bKoQcOUv_guR3DlwxkddsKzIiYl-fw7BTRRxmVsDOyBw_XjcY1OFHloSXtaU=w1052-h592'
  ];
  const detailFallbackThumb = id => detailFallbackThumbs[Number(id || 0) % detailFallbackThumbs.length];
  const detailTitle = String(acc.title || acc.rank || acc.acc_info || 'Acc đang bán').trim();
  const galleryImages = images.length > 0 ? images : [detailFallbackThumb(acc.id)];
  const galleryImagesJson = JSON.stringify(galleryImages).replace(/</g, '\\u003c');
%>

<div class="detail-page">
  <div class="container">

    <%# ── BREADCRUMB ── %>
    <nav class="breadcrumb">
      <a href="/"><i class="fas fa-home"></i> Trang Chủ</a>
      <i class="fas fa-chevron-right"></i>
      <a href="/game/<%= category.slug %>"><%= category.icon %> <%= category.name %></a>
      <i class="fas fa-chevron-right"></i>
      <span><%= detailTitle %></span>
    </nav>

    <div class="detail-grid">

      <%# ── LEFT: IMAGE GALLERY ── %>
      <div class="detail-gallery">
        <div class="main-img-wrap">
          <img src="<%= galleryImages[0] %>" alt="<%= detailTitle %>" id="mainImg" class="main-img" onclick="openImageModal()" onerror="this.src='<%= detailFallbackThumb(acc.id) %>'">
          <span class="detail-badge"><%= acc.status === 'available' ? '🟢 Còn hàng' : '🔴 Hết hàng' %></span>
          <% if (galleryImages.length > 1) { %>
            <button type="button" class="gallery-nav gallery-prev" onclick="event.stopPropagation();changeMainImage(-1)" aria-label="Ảnh trước"><i class="fas fa-chevron-left"></i></button>
            <button type="button" class="gallery-nav gallery-next" onclick="event.stopPropagation();changeMainImage(1)" aria-label="Ảnh sau"><i class="fas fa-chevron-right"></i></button>
          <% } %>
        </div>
        <% if (galleryImages.length > 1) { %>
        <div class="thumb-list">
          <% galleryImages.forEach((img, i) => { %>
          <img src="<%= img %>" alt="Ảnh <%= i+1 %>" class="thumb-item <%= i === 0 ? 'active' : '' %>"
               onclick="setMainIndex(<%= i %>)" ondblclick="openImageModal(<%= i %>)">
          <% }) %>
        </div>
        <% } %>
      </div>

      <%# ── RIGHT: INFO ── %>
      <div class="detail-info">
        <div class="detail-id">Acc #<%= acc.id %></div>
        <h1 class="detail-rank"><%= detailTitle %></h1>
        <% if (acc.acc_info) { %><p class="detail-title-text"><%= acc.acc_info %></p><% } %>

        <%# ── THÔNG SỐ ── %>
        <div class="detail-specs">
          <% if (acc.so_tuong > 0) { %>
          <div class="spec-item">
            <i class="fas fa-user-ninja"></i>
            <span class="spec-key">Số tướng:</span>
            <span class="spec-val"><%= acc.so_tuong %></span>
          </div>
          <% } %>
          <% if (acc.trang_phuc > 0) { %>
          <div class="spec-item">
            <i class="fas fa-tshirt"></i>
            <span class="spec-key">Trang phục:</span>
            <span class="spec-val"><%= acc.trang_phuc %></span>
          </div>
          <% } %>
          <% if (acc.ngoc > 0) { %>
          <div class="spec-item">
            <i class="fas fa-gem"></i>
            <span class="spec-key">Số ngọc:</span>
            <span class="spec-val"><%= acc.ngoc %></span>
          </div>
          <% } %>
          <% if (acc.server) { %>
          <div class="spec-item">
            <i class="fas fa-server"></i>
            <span class="spec-key">Server:</span>
            <span class="spec-val"><%= acc.server %></span>
          </div>
          <% } %>
        </div>

        <%# ── GIÁ & MUA ── %>
        <div class="detail-price-box">
          <div class="detail-price">
            <span class="price-label">Giá ATM:</span>
            <span class="price-value"><%= Number(acc.price).toLocaleString('vi-VN') %>đ</span>
          </div>
          <% if (acc.status === 'available') { %>
            <% if (user) { %>
              <div class="balance-info">
                Số dư của bạn: <strong><span id="userBalance"><%= Number(user.balance).toLocaleString('vi-VN') %></span>đ</strong>
                <% if (Number(user.balance) < Number(acc.price)) { %>
                  <a href="/nap-tien" class="btn-napngay">Nạp tiền ngay</a>
                <% } %>
              </div>
            <% } %>
            <button class="btn-buy-detail" id="buyBtn" onclick="buyThisAcc()">
              <i class="fas fa-shopping-cart"></i>
              <% if (!user) { %>Đăng nhập để mua
              <% } else if (Number(user.balance) < Number(acc.price)) { %>Số dư không đủ
              <% } else { %>Mua Ngay – <%= Number(acc.price).toLocaleString('vi-VN') %>đ<% } %>
            </button>
          <% } else if (typeof userOrder !== 'undefined' && userOrder) { %>
            <%# Acc đã bán – hiện thông tin cho người đã mua %>
            <div class="bought-creds-box">
              <div class="bought-creds-title"><i class="fas fa-check-circle"></i> Bạn đã mua acc này</div>
              <div class="cred-row">
                <span class="cred-label">Tài khoản</span>
                <span class="cred-value" id="credUser"><%= userOrder.acc_username %></span>
                <button onclick="navigator.clipboard.writeText('<%= userOrder.acc_username %>');this.innerHTML='✓'" class="btn-copy"><i class="fas fa-copy"></i></button>
              </div>
              <div class="cred-row">
                <span class="cred-label">Mật khẩu</span>
                <span class="cred-value" id="credPass"><%= userOrder.acc_password %></span>
                <button onclick="navigator.clipboard.writeText('<%= userOrder.acc_password %>');this.innerHTML='✓'" class="btn-copy"><i class="fas fa-copy"></i></button>
              </div>
              <% if (userOrder.acc_server) { %>
              <div class="cred-row">
                <span class="cred-label">Server</span>
                <span class="cred-value"><%= userOrder.acc_server %></span>
              </div>
              <% } %>
              <div class="bought-date">Mua lúc: <%= new Date(userOrder.created_at).toLocaleString('vi-VN') %></div>
            </div>
          <% } else { %>
            <button class="btn-buy-detail sold" disabled>Đã Bán</button>
          <% } %>
        </div>

        <%# ── AUTO DELIVERY NOTE ── %>
        <div class="auto-note">
          <i class="fas fa-bolt"></i>
          <div>
            <strong>Nhận acc ngay sau khi mua!</strong>
            <span>Hệ thống tự động giao acc trong vòng vài giây</span>
          </div>
        </div>

        <%# ── SUPPORT LINKS ── %>
        <div class="support-links">
          <a href="https://zalo.me/g/gssfxa652" target="_blank" class="supp-btn zalo">
            <i class="fas fa-comment-dots"></i> Hỗ trợ Zalo
          </a>
          <a href="https://www.facebook.com/share/18jMzbCfXh/" target="_blank" class="supp-btn fb">
            <i class="fab fa-facebook"></i> Facebook
          </a>
        </div>
        <a href="https://id.onlive.vn/bao-mat-tai-khoan?tab=password" target="_blank" rel="noopener" class="password-change-link">
          <i class="fas fa-key"></i>
          <span>Đổi mật khẩu tài khoản Onlive/VPlay</span>
        </a>
      </div>

    </div><%# end detail-grid %>

    <%# ── ACC LIÊN QUAN ── %>
    <% if (related && related.length > 0) { %>
    <section class="related-section">
      <h2 class="section-title"><i class="fas fa-layer-group"></i> Acc Tương Tự</h2>
      <div class="acc-grid">
        <% related.forEach(r => { %>
        <div class="acc-card" onclick="location.href='/game/<%= category.slug %>/<%= r.id %>'">
          <div class="acc-thumb">
            <% if (r.thumb) { %>
              <img src="<%= r.thumb %>" alt="<%= r.rank %>" loading="lazy" onerror="this.src='<%= detailFallbackThumb(r.id) %>'">
            <% } else { %>
              <img src="<%= detailFallbackThumb(r.id) %>" alt="Acc #<%= r.id %>" loading="lazy">
            <% } %>
          </div>
          <div class="acc-info">
            <h3 class="acc-rank"><%= r.title || r.rank || 'N/A' %></h3>
            <div class="acc-footer">
              <span class="acc-price"><%= Number(r.price).toLocaleString('vi-VN') %>đ</span>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

  </div>
</div>

<div class="image-modal" id="imageModal" onclick="closeImageModal()">
  <button type="button" class="image-modal-close" aria-label="Đóng ảnh">×</button>
  <% if (galleryImages.length > 1) { %>
    <button type="button" class="image-modal-nav image-modal-prev" onclick="event.stopPropagation();changeModalImage(-1)" aria-label="Ảnh trước"><i class="fas fa-chevron-left"></i></button>
    <button type="button" class="image-modal-nav image-modal-next" onclick="event.stopPropagation();changeModalImage(1)" aria-label="Ảnh sau"><i class="fas fa-chevron-right"></i></button>
  <% } %>
  <img src="" alt="Ảnh acc full" id="imageModalImg" onclick="event.stopPropagation()">
</div>

<%# ── BUY RESULT MODAL ── %>
<div class="modal-overlay" id="buyModal" style="display:none">
  <div class="modal-box">
    <div class="modal-header">
      <h3><i class="fas fa-shopping-cart"></i> Kết Quả Mua Acc</h3>
      <button onclick="document.getElementById('buyModal').style.display='none'" class="modal-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" id="buyModalBody"></div>
  </div>
</div>


<script>
const galleryImages = <%- galleryImagesJson %>;
let currentImageIndex = 0;
let modalImageIndex = 0;

function setMainIndex(index) {
  currentImageIndex = (index + galleryImages.length) % galleryImages.length;
  document.getElementById('mainImg').src = galleryImages[currentImageIndex];
  document.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('active'));
  const activeThumb = document.querySelectorAll('.thumb-item')[currentImageIndex];
  if (activeThumb) activeThumb.classList.add('active');
}

function changeMainImage(step) {
  setMainIndex(currentImageIndex + step);
}

function openImageModal(index = currentImageIndex) {
  modalImageIndex = (index + galleryImages.length) % galleryImages.length;
  const modal = document.getElementById('imageModal');
  document.getElementById('imageModalImg').src = galleryImages[modalImageIndex];
  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
}

function changeModalImage(step) {
  modalImageIndex = (modalImageIndex + step + galleryImages.length) % galleryImages.length;
  document.getElementById('imageModalImg').src = galleryImages[modalImageIndex];
}

function closeImageModal() {
  const modal = document.getElementById('imageModal');
  modal.classList.remove('active');
  document.getElementById('imageModalImg').src = '';
  document.body.style.overflow = '';
}

function bindImageSwipe(el, onSwipe) {
  if (!el || galleryImages.length <= 1) return;
  let startX = 0;
  let startY = 0;
  let moved = false;

  el.addEventListener('touchstart', event => {
    const touch = event.touches && event.touches[0];
    if (!touch) return;
    startX = touch.clientX;
    startY = touch.clientY;
    moved = false;
  }, { passive: true });

  el.addEventListener('touchmove', event => {
    const touch = event.touches && event.touches[0];
    if (!touch) return;
    if (Math.abs(touch.clientX - startX) > 10) moved = true;
  }, { passive: true });

  el.addEventListener('touchend', event => {
    const touch = event.changedTouches && event.changedTouches[0];
    if (!touch || !moved) return;
    const dx = touch.clientX - startX;
    const dy = touch.clientY - startY;
    if (Math.abs(dx) < 42 || Math.abs(dx) < Math.abs(dy)) return;
    onSwipe(dx < 0 ? 1 : -1);
  }, { passive: true });
}

document.addEventListener('DOMContentLoaded', () => {
  bindImageSwipe(document.querySelector('.main-img-wrap'), changeMainImage);
  bindImageSwipe(document.getElementById('imageModal'), changeModalImage);
});

document.addEventListener('keydown', event => {
  const modal = document.getElementById('imageModal');
  if (!modal || !modal.classList.contains('active')) return;
  if (event.key === 'ArrowLeft') changeModalImage(-1);
  if (event.key === 'ArrowRight') changeModalImage(1);
  if (event.key === 'Escape') closeImageModal();
});

function buyThisAcc() {
  <% if (!user) { %>
    window.location.href = '/dang-nhap?returnUrl=' + encodeURIComponent(window.location.pathname);
    return;
  <% } %>
  <% if (user && Number(user.balance) < Number(acc.price)) { %>
    window.location.href = '/nap-tien';
    return;
  <% } %>

  const btn = document.getElementById('buyBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';

  fetch('/api/buy/<%= acc.id %>', { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      document.getElementById('buyModal').style.display = 'flex';
      if (data.success) {
        document.getElementById('buyModalBody').innerHTML = `
          <div style="text-align:center;margin-bottom:16px">
            <i class="fas fa-check-circle" style="color:#2ecc71;font-size:3rem"></i>
            <h3 style="color:#2ecc71;margin:10px 0">Mua Thành Công! 🎉</h3>
          </div>
          <div class="cred-item">
            <label>Tên đăng nhập:</label>
            <span class="cred-value">${data.order.acc_username}</span>
            <button onclick="navigator.clipboard.writeText('${data.order.acc_username}')" class="btn-copy"><i class="fas fa-copy"></i></button>
          </div>
          <div class="cred-item">
            <label>Mật khẩu:</label>
            <span class="cred-value">${data.order.acc_password}</span>
            <button onclick="navigator.clipboard.writeText('${data.order.acc_password}')" class="btn-copy"><i class="fas fa-copy"></i></button>
          </div>
          ${data.order.acc_info ? `<div class="cred-item"><label>Lưu ý:</label><span style="color:#ccc">${data.order.acc_info}</span></div>` : ''}
          <p style="color:var(--accent);font-weight:700;margin-top:12px">Số dư còn: ${Number(data.new_balance).toLocaleString('vi-VN')}đ</p>
          <a href="https://id.onlive.vn/bao-mat-tai-khoan?tab=password" target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;gap:8px;background:#111;color:#fff;text-decoration:none;border-radius:8px;padding:11px 12px;margin-top:12px;font-size:.9rem;font-weight:800;">
            <i class="fas fa-key"></i> Đổi mật khẩu Onlive/VPlay
          </a>
        `;
        btn.innerHTML = '✅ Đã mua thành công';
        btn.className = 'btn-buy-detail sold';
      } else {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-shopping-cart"></i> Mua Ngay';
        document.getElementById('buyModalBody').innerHTML = `
          <div style="text-align:center">
            <i class="fas fa-times-circle" style="color:#e74c3c;font-size:3rem"></i>
            <p style="color:#e74c3c;margin:12px 0">${data.message}</p>
            ${data.redirect ? `<a href="${data.redirect}" style="color:var(--primary)">Nạp tiền ngay</a>` : ''}
          </div>
        `;
      }
    })
    .catch(() => {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-shopping-cart"></i> Mua Ngay';
      alert('Lỗi kết nối. Vui lòng thử lại!');
    });
}
document.getElementById('buyModal')?.addEventListener('click', e => {
  if (e.target.id === 'buyModal') e.target.style.display = 'none';
});
</script>

<%# ===== TRANG ĐĂNG NHẬP ===== %>
<div class="auth-wrap">
  <div class="auth-card">

    <div class="auth-header">
      <div class="auth-logo">🏪</div>
      <h1>Đăng Nhập</h1>
      <p>Chào mừng trở lại SHOPMEBU.VN!</p>
    </div>

    <% if (error_msg && error_msg.length > 0) { %>
      <div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= error_msg[0] %></div>
    <% } %>
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success_msg[0] %></div>
    <% } %>
    <% if (typeof query !== 'undefined' && query === 'google') { %>
      <div class="flash flash-error">Đăng nhập Google thất bại. Vui lòng thử lại!</div>
    <% } %>
    <%# OAUTH BUTTONS %>
    <div class="oauth-btns">
      <a href="/auth/google" class="oauth-btn oauth-google">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Đăng nhập với Google
      </a>
    </div>

    <div class="oauth-hint">
      <i class="fas fa-info-circle"></i>
      Đăng ký bằng Google? Nhấn nút trên là vào ngay — không cần mật khẩu!
    </div>

    <div class="auth-divider"><span>hoặc đăng nhập bằng tài khoản thủ công</span></div>

    <%# FORM ĐĂNG NHẬP %>
    <form action="/dang-nhap" method="POST">
      <input type="hidden" name="returnUrl" value="<%= returnUrl %>">

      <div class="form-group">
        <label><i class="fas fa-user"></i> Tên đăng nhập / Email</label>
        <input class="form-control" type="text" name="username"
               placeholder="Nhập username hoặc email" required autofocus autocomplete="username">
      </div>

      <div class="form-group">
        <label><i class="fas fa-lock"></i> Mật khẩu</label>
        <div class="input-group">
          <input class="form-control" type="password" name="password" id="pwInput"
                 placeholder="Nhập mật khẩu" required autocomplete="current-password">
          <button type="button" class="toggle-pw" onclick="togglePw('pwInput','pwIcon')">
            <i class="fas fa-eye" id="pwIcon"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="form-submit">
        <i class="fas fa-sign-in-alt"></i> Đăng Nhập
      </button>
    </form>

    <div class="auth-switch" style="margin-top:18px;">
      Chưa có tài khoản? <a href="/dang-ky">Đăng ký ngay</a>
    </div>
  </div>
</div>

<style>
.oauth-hint {
  background:linear-gradient(135deg,#e3f2fd,#e8f5e9);
  border:1.5px solid #90caf9; border-radius:10px;
  padding:10px 14px; font-size:12.5px; color:#1565c0;
  display:flex; align-items:center; gap:8px; margin-bottom:6px;
}
.oauth-btns { display:flex; flex-direction:column; gap:10px; margin-bottom:4px; }
.oauth-btn {
  display:flex; align-items:center; justify-content:center; gap:10px;
  padding:12px 20px; border-radius:12px; font-size:14px; font-weight:700;
  text-decoration:none; transition:all .2s; border:2px solid transparent;
}
.oauth-google {
  background:#fff; border-color:#dadce0; color:#3c4043;
  box-shadow:0 1px 6px rgba(0,0,0,.08);
}
.oauth-google:hover { border-color:#4285f4; box-shadow:0 3px 14px rgba(66,133,244,.2); background:#f8f9ff; }
@media (max-width:480px) {
  .oauth-btn { font-size:13px; padding:11px 14px; }
}
</style>

<script>
function togglePw(inputId, iconId) {
  const inp = document.getElementById(inputId);
  const ico = document.getElementById(iconId);
  if (inp.type === 'password') { inp.type = 'text'; ico.className = 'fas fa-eye-slash'; }
  else { inp.type = 'password'; ico.className = 'fas fa-eye'; }
}
</script>

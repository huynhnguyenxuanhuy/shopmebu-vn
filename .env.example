# ===== SERVER =====
PORT=3000
NODE_ENV=development
BASE_URL=http://127.0.0.1:3000
TRUST_PROXY=0
COOKIE_SECURE=0
SESSION_NAME=shopmebu.sid

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=shopmebu
DB_SSL=0
DB_SSL_REJECT_UNAUTHORIZED=true

# ===== SESSION =====
SESSION_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
# Development để trống sẽ dùng memory. Production để trống sẽ dùng MySQL session.
# Có thể đặt SESSION_STORE=mysql để ép dùng MySQL khi test local.
SESSION_STORE=
SESSION_TABLE=user_sessions

# ===== BASIC FIREWALL / RATE LIMIT =====
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb
RATE_LIMIT_GLOBAL=900
RATE_LIMIT_AUTH=20
RATE_LIMIT_BUY=30
RATE_LIMIT_WEBHOOK=180
RATE_LIMIT_ADMIN=240

# ===== UPLOAD =====
UPLOAD_PATH=public/uploads
MAX_FILE_SIZE=5242880

# ===== SEPAY WEBHOOK =====
# Lấy từ dashboard SePay: https://sepay.vn
# Webhook production: https://shopmebu.vn/api/webhook/sepay
SEPAY_WEBHOOK_TOKEN=your_sepay_token_here

# ===== ZALO OA =====
ZALO_OA_TOKEN=

# ===== GOOGLE OAUTH =====
# Tạo tại: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://shopmebu.vn/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://shopmebu.vn/auth/google/callback
